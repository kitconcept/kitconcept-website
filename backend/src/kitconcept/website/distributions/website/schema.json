{
  "schema": {
    "title": "kitconcept Site",
    "description": "Create a new Site based on Plone.",
    "type": "object",
    "definitions": {
      "languages": {
        "type": "string",
        "title": "Language",
        "anyOf": [
          {
            "type": "string",
            "enum": ["de"],
            "title": "Deutsch"
          },
          {
            "type": "string",
            "enum": ["en"],
            "title": "English"
          }
        ]
      }
    },
    "properties": {
      "site_id": {
        "type": "string",
        "title": "Path Identifier",
        "default": "Plone",
        "description": "The ID of the site. No special characters or spaces are allowed. This ends up as part of the URL unless hidden by an upstream web server."
      },
      "title": {
        "type": "string",
        "title": "Title",
        "default": "Site",
        "description": "A short title for the site. This will be shown as part of the title of the browser window on each page."
      },
      "description": {
        "type": "string",
        "title": "Site Description",
        "default": "A Plone Site"
      },
      "site_logo": {
        "type": "string",
        "format": "data-url",
        "title": "Site logo"
      },
      "available_languages": {
        "type": "array",
        "title": "Available Languages",
        "description": "Languages that will be available. If more than one language is selected, the first one in the list will be the default language.",
        "items": {"$ref": "#/definitions/languages"},
        "default": ["de"]
      },
      "default_language": {
        "type": "string",
        "title": "Default Language",
        "default": ""
      },
      "setup_content": {
        "type": "boolean",
        "title": "Create Example Content",
        "description": "Should example content be added during site creation?",
        "default": true
      },
      "authentication": {
        "title": "Authentication",
        "type": "object",
        "properties": {
          "provider" : {
            "type": "string",
            "title": "User authentication",
            "description": "Which authentication would be used?",
            "default": "internal",
            "oneOf": [
              { "const": "internal", "title": "Plone" },
              { "const": "keycloak", "title": "Keycloak" },
              { "const": "oidc", "title": "OIDC / OAuth2" },
              { "const": "authomatic-google", "title": "Social Login Google" },
              { "const": "authomatic-github", "title": "Social Login GitHub" }
            ]
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "provider": {
                  "const": "keycloak"
                }
              }
            },
            "then": {
              "$ref": "#/definitions/keycloak"
            }
          },
          {
            "if": {
              "properties": {
                "provider": {
                  "const": "oidc"
                }
              }
            },
            "then": {
              "$ref": "#/definitions/oidc"
            }
          },
          {
            "if": {
              "properties": {
                "provider": {
                  "const": "authomatic-github"
                }
              }
            },
            "then": {
              "$ref": "#/definitions/authomatic-github"
            }
          },
          {
            "if": {
              "properties": {
                "provider": {
                  "const": "authomatic-google"
                }
              }
            },
            "then": {
              "$ref": "#/definitions/authomatic-google"
            }
          },
          {
            "if": {
              "properties": {
                "provider": {
                  "const": "internal"
                }
              }
            },
            "then": {
              "properties": {},
              "required": []
            }
          },
          {
            "required": [
              "provider"
            ]
          }
        ]
      }
    },
    "required": [
      "site_id",
      "title",
      "authentication"
    ]
  },
  "uischema": {
    "site_id": {"ui:widget": "hidden"},
    "default_language": {"ui:widget": "hidden"}
  }
}
